DJANGO_SECRET_KEY=dev-only-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
APP_TIMEZONE=UTC
# Comma-separated. Add your deployed UI origin (not the Railway API host), e.g. https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Choose sqlite or postgres
DB_BACKEND=sqlite

# SQLite mode (used when DB_BACKEND=sqlite)
SQLITE_PATH=/Users/mac/spotter_ai/backend/db.sqlite3

# Postgres mode (used when DB_BACKEND=postgres)
POSTGRES_DB=spotter_ai
POSTGRES_USER=spotter
POSTGRES_PASSWORD=spotter
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# Route provider: osrm or stub
ROUTE_PROVIDER=osrm
