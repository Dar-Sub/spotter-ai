# Copy to backend/.env and fill in real values. Never commit backend/.env.
#
# Security: all values below are placeholders. Generate secrets locally and keep them private.

# Django — use a long random string per environment (do not reuse across deploys):
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=__REPLACE_ME_GENERATE_A_RANDOM_SECRET__

DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ELD day boundaries + default shift date use this zone (IANA name). Production: set to your ops timezone, e.g. America/Chicago.
APP_TIMEZONE=UTC

# Comma-separated. Add your deployed UI origin (not the API host), e.g. https://your-frontend.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Choose sqlite or postgres
DB_BACKEND=sqlite

# SQLite: optional. If unset, Django uses backend/db.sqlite3 (next to manage.py).
# Use an absolute path only in your private .env — do not put real paths in shared templates.
# SQLITE_PATH=

# Postgres (used when DB_BACKEND=postgres) — use strong passwords in production; never commit real credentials.
POSTGRES_DB=#
POSTGRES_USER=#
POSTGRES_PASSWORD=__REPLACE_ME_STRONG_PASSWORD__
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# Route provider: osrm or stub
ROUTE_PROVIDER=osrm
